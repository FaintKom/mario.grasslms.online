<?xml version="1.0" encoding="UTF-8"?>
<!--
  SCORM 1.2 manifest · Module 5 · Product Prop Mapping (multi-stakeholder)
  Identifier: FTC.SDR.M5.product-prop-mapping.v1
  Class 5 (multi-stakeholder) per 4cid-blueprint.md §3.1 — task class is
  derived from brief §12.2 (Tom + finance peer) + §12.3 (Emma + bookkeeper)
  substrate (no §11 Gong evidence yet; cohort-1 Gong validates LO-PP.3
  threshold — see design-log.md §1 + storyboard Evidence note).
  Single SCO. Shell at ../scorm-shell/ is copied alongside on packaging.
-->
<manifest identifier="FTC.SDR.M5.product-prop-mapping.v1"
          version="1.0.0"
          xmlns="http://www.imsproject.org/xsd/imscp_rootv1p1p2"
          xmlns:adlcp="http://www.adlnet.org/xsd/adlcp_rootv1p2"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://www.imsproject.org/xsd/imscp_rootv1p1p2 imscp_rootv1p1p2.xsd
                              http://www.imsproject.org/xsd/imsmd_rootv1p2p1 imsmd_rootv1p2p1.xsd
                              http://www.adlnet.org/xsd/adlcp_rootv1p2     adlcp_rootv1p2.xsd">

  <metadata>
    <schema>ADL SCORM</schema>
    <schemaversion>1.2</schemaversion>
  </metadata>

  <organizations default="FTC-SDR-ONBOARDING">
    <organization identifier="FTC-SDR-ONBOARDING">
      <title>FinTechCard SDR Onboarding</title>
      <item identifier="ITEM-M5" identifierref="RES-M5" isvisible="true">
        <title>Module 5 · Product Prop Mapping (multi-stakeholder)</title>
        <adlcp:masteryscore>80</adlcp:masteryscore>
        <adlcp:maxtimeallowed>00:10:00</adlcp:maxtimeallowed>
        <adlcp:timelimitaction>continue,no message</adlcp:timelimitaction>
        <adlcp:datafromlms></adlcp:datafromlms>
      </item>
    </organization>
  </organizations>

  <resources>
    <resource identifier="RES-M5"
              type="webcontent"
              adlcp:scormtype="sco"
              href="index.html">
      <file href="index.html"/>
      <file href="styles.css"/>
      <file href="module.js"/>
      <file href="data/transcripts.json"/>
      <file href="data/prospects.json"/>
      <file href="data/prop-pain-bank.json"/>
      <file href="data/quiz.json"/>
      <dependency identifierref="RES-SHELL"/>
    </resource>

    <resource identifier="RES-SHELL"
              type="webcontent"
              adlcp:scormtype="asset"
              href="../scorm-shell/index.html">
      <file href="../scorm-shell/js/shell.js"/>
      <file href="../scorm-shell/js/scorm-bridge.js"/>
      <file href="../scorm-shell/js/event-log.js"/>
      <file href="../scorm-shell/js/coach-marks.js"/>
      <file href="../scorm-shell/js/apps/registry.js"/>
      <file href="../scorm-shell/js/apps/outreach.js"/>
      <file href="../scorm-shell/js/apps/gong.js"/>
      <file href="../scorm-shell/js/apps/salesforce.js"/>
      <file href="../scorm-shell/js/apps/linkedin-ch.js"/>
      <file href="../scorm-shell/js/apps/calendar.js"/>
      <file href="../scorm-shell/js/apps/phone-dialler.js"/>
      <file href="../scorm-shell/js/apps/slack.js"/>
      <file href="../scorm-shell/styles/shell.css"/>
      <file href="../scorm-shell/styles/apps.css"/>
    </resource>
  </resources>
</manifest>
